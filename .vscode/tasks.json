{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Install Backend",
			"type": "shell",
			"command": "pip install -r requirements.txt",
			"options": {
				"cwd": "${workspaceFolder}/backend"
			}
		},
		{
			"label": "Run Backend",
			"type": "shell",
			"command": "uvicorn main:app --reload",
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"presentation": {
				"reveal": "always",
				"panel": "new"
			},
			"problemMatcher": []
		},
		{
			"label": "Install Frontend",
			"type": "shell",
			"command": "npm install",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			}
		},
		{
			"label": "Run Frontend",
			"type": "shell",
			"command": "npm run dev",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"presentation": {
				"reveal": "always",
				"panel": "new"
			},
			"problemMatcher": []
		}
	]
}
